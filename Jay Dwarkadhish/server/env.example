# Jay Dwarkadhish Accounting Services – Environment Variables
# Copy this file to .env and fill in your credentials

# Gmail address used to send emails
EMAIL_USER=

# Gmail App Password (NOT your normal password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASS=

# Destination inbox for contact-form submissions (optional)
# If omitted, EMAIL_USER is used.
EMAIL_TO=

# Port for the server (default: 3000)
PORT=3000
